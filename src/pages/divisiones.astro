---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';

const currentPath = '/divisiones';
---

<Layout title="The Roster">
  <Navbar client:load currentPath={currentPath} />

  <main class="flex-grow pt-32 pb-24 px-6 md:px-12 max-w-screen-2xl mx-auto w-full">
    <!-- Header Section -->
    <section class="mb-16">
      <h1 class="text-5xl md:text-7xl font-bold tracking-[-0.02em] text-on-surface mb-6 uppercase">The <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-container to-on-primary-fixed-variant">Roster</span></h1>
      <p class="text-xl md:text-2xl text-on-surface-variant font-medium max-w-3xl leading-relaxed">Elite talent across music, sports, and entertainment. Uncompromising excellence.</p>
    </section>

    <!-- Filters -->
    <section class="mb-12 flex flex-wrap gap-4">
      <button class="px-6 py-3 rounded-full bg-primary-container text-on-primary font-bold uppercase tracking-[0.05em] text-sm transition-transform hover:scale-105">All Access</button>
      <button class="px-6 py-3 rounded-full bg-surface-container-high text-on-surface font-medium uppercase tracking-[0.05em] text-sm border border-outline-variant/20 hover:bg-surface-bright transition-colors">Music</button>
      <button class="px-6 py-3 rounded-full bg-surface-container-high text-on-surface font-medium uppercase tracking-[0.05em] text-sm border border-outline-variant/20 hover:bg-surface-bright transition-colors">Sports</button>
      <button class="px-6 py-3 rounded-full bg-surface-container-high text-on-surface font-medium uppercase tracking-[0.05em] text-sm border border-outline-variant/20 hover:bg-surface-bright transition-colors">Entertainment</button>
    </section>

    <!-- Talent Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <!-- Talent Card 1 -->
      <div class="group relative rounded-sm overflow-hidden bg-surface-container-low aspect-[4/5] cursor-pointer transition-transform duration-500 hover:scale-[1.02]">
        <img alt="Talent" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA9gNl0xHLrSCWzxiANvKpSrtEr7OKxG9dNARR5aINar3nxHu0tjH3tFjvVGEs-k8b1TN4y6lSMqdpZFU7IdKkvGmy2xPpGEd8raDk0UgRPQDvgNKnoZ1AzjdlpefSNfpAOM5aSPRk6GNgx7K-mpJRLJCNK7kbe3EcSfTin_PrwSRVWb2ZiZElyjZTTzjAfTTbQ8xrZJWVoWG3_o9PCjktQjJ4TVEMSoqzKZ9OWIzBq7kJLzKcLBCNiX2OfiIi2gutqkEDJrwR8E62P"/>
        <div class="absolute inset-0 bg-gradient-to-t from-[#131313] via-[#131313]/40 to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-full p-6">
          <span class="inline-block px-3 py-1 bg-surface/80 backdrop-blur-md rounded-sm text-primary uppercase tracking-[0.05em] text-xs font-bold mb-3 border border-outline-variant/20">Billboard Chart Topper</span>
          <h2 class="text-3xl font-bold tracking-tight text-white uppercase">Elena Rossi</h2>
          <p class="text-white/60 font-medium text-sm mt-1 uppercase tracking-wider">Music</p>
        </div>
      </div>

      <!-- Talent Card 2 -->
      <div class="group relative rounded-sm overflow-hidden bg-surface-container-low aspect-[4/5] cursor-pointer transition-transform duration-500 hover:scale-[1.02]">
        <img alt="Talent" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAztbERVLPlrrpmtjLihwdMGKZiPeHPbXEw2FWL1Yd0O7zGMr-e5AgmeAadpIax31MlzUt87PcigAKBBjgt5_GzJh6zRDpQZ-EY4m9EblzgKZGEqk4u_OX6SYSjhkz09ImUpz18OLM9TaCAuwGWaTEaROow0jvqurmAAQWC_jleKtMaVxAMDjPcvTI8vcbuatg4siXaylOFehUEusA6gIgdFv98ll5fwtSiXLLcyDeEOPfKFc3kH_klCTPgs8xJwEUpPbe1qUuXBNLB"/>
        <div class="absolute inset-0 bg-gradient-to-t from-[#131313] via-[#131313]/40 to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-full p-6">
          <span class="inline-block px-3 py-1 bg-surface/80 backdrop-blur-md rounded-sm text-primary uppercase tracking-[0.05em] text-xs font-bold mb-3 border border-outline-variant/20">Olympic Gold</span>
          <h2 class="text-3xl font-bold tracking-tight text-white uppercase">Marcus Vance</h2>
          <p class="text-white/60 font-medium text-sm mt-1 uppercase tracking-wider">Sports</p>
        </div>
      </div>

      <!-- Talent Card 3 -->
      <div class="group relative rounded-sm overflow-hidden bg-surface-container-low aspect-[4/5] cursor-pointer transition-transform duration-500 hover:scale-[1.02]">
        <img alt="Talent" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBa_BviJQ0G6HnWuKSceB1q7hF4IaLdGShI7zKxQdWm4Qfq8qCT3-TP3s9mtOjUb9T6IlSnnTxdBnRxjK6weviyvk50RChrLKKPn8SCUK698zRB-o9LIkqaeejdWUVBcHPNbA5FSgW2JhOqLILB6ZyyKQ4SBgk3976b9LI5GLx6Zu6lIrLZ0-sOn9SUUMx9WzXKfhrUAfg04WIgI33Tv4bsQ_unAUOu_yrwjoF6Ru34uFxDdZXMTeTao3E2GhiKuRtpbpdk4-r1ay91"/>
        <div class="absolute inset-0 bg-gradient-to-t from-[#131313] via-[#131313]/40 to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-full p-6">
          <span class="inline-block px-3 py-1 bg-surface/80 backdrop-blur-md rounded-sm text-primary uppercase tracking-[0.05em] text-xs font-bold mb-3 border border-outline-variant/20">Oscar Nominee</span>
          <h2 class="text-3xl font-bold tracking-tight text-white uppercase">Sarah Jenkins</h2>
          <p class="text-white/60 font-medium text-sm mt-1 uppercase tracking-wider">Entertainment</p>
        </div>
      </div>

      <!-- Talent Card 4 -->
      <div class="group relative rounded-sm overflow-hidden bg-surface-container-low aspect-[4/5] cursor-pointer transition-transform duration-500 hover:scale-[1.02]">
        <img alt="Talent" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZwyUjXRf9f3GM2BmThObM0Oog1ggiNVDSK9V2b_LCXY0MmBRBTYLE6IeOsJbE3WAaufmHJ9caqQkGwAFmzmdlU-sdrSPXkesQLNbEiZqKBQrNyypkS6cfVr2hGxYKbD1V9SESd3HcMb4nXz5bNwn2GYnM-tuFeiSaa3npGryBd13UxGbrM5_eWvb0pPWB9D3rSMZ3QtmoimxYfOw_yc-6Im8v9av_bwLbMSNwLIhOP-l-bgDa5-dHEuh4o5qUqrwTrmcXALEWXPwx"/>
        <div class="absolute inset-0 bg-gradient-to-t from-[#131313] via-[#131313]/40 to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-full p-6">
          <span class="inline-block px-3 py-1 bg-surface/80 backdrop-blur-md rounded-sm text-primary uppercase tracking-[0.05em] text-xs font-bold mb-3 border border-outline-variant/20">Platinum Record</span>
          <h2 class="text-3xl font-bold tracking-tight text-white uppercase">J-Dash</h2>
          <p class="text-white/60 font-medium text-sm mt-1 uppercase tracking-wider">Music</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
